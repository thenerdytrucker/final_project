# Required for Nebius AI Studio LLM parsing/generation
NEBIUS_API_KEY=your_nebius_api_key_here
NEBIUS_BASE_URL=https://api.studio.nebius.com/v1/
NEBIUS_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct

# MLflow tracking storage (inside container)
MLFLOW_TRACKING_URI=sqlite:////app/data/mlflow.db
MLFLOW_EXPERIMENT_NAME=pima_diabetes_sprint17

# If true, app auto-creates 5 experiment runs when none exist
AUTO_BOOTSTRAP_RUNS=true
